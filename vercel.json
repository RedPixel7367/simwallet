{
  "version": 2,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/login", "dest": "backend/server.js" },
    { "src": "/update", "dest": "backend/server.js" },
    { "src": "/admin/keys", "dest": "backend/server.js" },
    { "src": "/admin/delete", "dest": "backend/server.js" },
    { "src": "/", "dest": "frontend/login.html" },
    { "src": "/dashboard", "dest": "frontend/dashboard.html" },
    { "src": "/admin", "dest": "frontend/admin.html" },
    { "src": "/(.*\\.html)", "dest": "frontend/$1" },
    { "src": "/(.*\\.js)", "dest": "frontend/$1" },
    { "src": "/(.*\\.png)", "dest": "frontend/$1" },
    { "src": "/(.*\\.json)", "dest": "frontend/$1" }
  ]
}